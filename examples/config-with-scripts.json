{
  "bar": {
    "position": "top",
    "height": 30,
    "background": "#1e1e2ecc",
    "color": "#cdd6f4",
    "font": "Noto Sans, Noto Color Emoji",
    "size": 10
  },
  "widgets": [
    {
      "type": "script",
      "position": "left",
      "config": {
        "command": "../widgets/cpu.sh",
        "interval": 2000,
        "color": "#f38ba8"
      }
    },
    {
      "type": "script",
      "position": "left",
      "config": {
        "command": "../widgets/memory.sh",
        "interval": 2000,
        "color": "#a6e3a1"
      }
    },
    {
      "type": "script",
      "position": "center",
      "config": {
        "command": "../widgets/date.sh",
        "interval": 1000
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "../widgets/battery.sh",
        "interval": 5000,
        "color": "#f9e2af"
      }
    },
    {
      "type": "tray",
      "position": "right",
      "config": {
        "icon_size": 20,
        "spacing": 8
      }
    }
  ]
}
