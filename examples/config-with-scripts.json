{
  "bar": {
    "position": "top",
    "height": 30,
    "background": "#1e1e2e",
    "foreground": "#cdd6f4",
    "font": "monospace"
  },
  "widgets": [
    {
      "type": "script",
      "position": "left",
      "config": {
        "command": "~/.config/hyprbar/widgets/cpu.sh",
        "interval": 2000,
        "font": "monospace",
        "size": 14,
        "color": "#f38ba8"
      }
    },
    {
      "type": "script",
      "position": "left",
      "config": {
        "command": "~/.config/hyprbar/widgets/memory.sh",
        "interval": 2000,
        "font": "monospace",
        "size": 14,
        "color": "#a6e3a1"
      }
    },
    {
      "type": "clock",
      "position": "center",
      "config": {
        "format": "%H:%M:%S",
        "font": "monospace",
        "size": 14
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "~/.config/hyprbar/widgets/battery.sh",
        "interval": 5000,
        "font": "monospace",
        "size": 14,
        "color": "#f9e2af"
      }
    }
  ]
}
