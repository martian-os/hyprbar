{
  "bar": {
    "position": "top",
    "height": 32,
    "background": "#1e1e2ecc",
    "color": "#cdd6f4",
    "font": "Noto Sans, Noto Color Emoji",
    "size": 14
  },
  "widgets": [
    {
      "type": "hyprland",
      "position": "left",
      "config": {
        "max_workspaces": 10,
        "active_color": "#89b4fa",
        "occupied_color": "#cdd6f4",
        "empty_color": "#45475a"
      }
    },
    {
      "type": "script",
      "position": "center",
      "config": {
        "command": "../widgets/date.sh",
        "interval": 1000,
        "color": "#89b4fa"
      }
    },
    {
      "type": "tray",
      "position": "right",
      "config": {
        "icon_size": 16,
        "spacing": 5
      }
    }
  ]
}
