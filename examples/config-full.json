{
  "bar": {
    "position": "top",
    "height": 32,
    "background": "#1e1e2e",
    "foreground": "#cdd6f4",
    "font": "monospace"
  },
  "widgets": [
    {
      "type": "script",
      "position": "left",
      "config": {
        "command": "~/.config/hyprbar/widgets/date.sh",
        "interval": 1000,
        "font": "monospace",
        "size": 14,
        "color": "#89b4fa"
      }
    },
    {
      "type": "script",
      "position": "left",
      "config": {
        "command": "~/.config/hyprbar/widgets/uptime.sh",
        "interval": 60000,
        "font": "monospace",
        "size": 12,
        "color": "#94e2d5"
      }
    },
    {
      "type": "script",
      "position": "center",
      "config": {
        "command": "~/.config/hyprbar/widgets/weather.sh",
        "interval": 300000,
        "font": "monospace",
        "size": 14,
        "color": "#f9e2af"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "~/.config/hyprbar/widgets/cpu.sh",
        "interval": 2000,
        "font": "monospace",
        "size": 12,
        "color": "#f38ba8"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "~/.config/hyprbar/widgets/memory.sh",
        "interval": 5000,
        "font": "monospace",
        "size": 12,
        "color": "#fab387"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "~/.config/hyprbar/widgets/disk.sh",
        "interval": 60000,
        "font": "monospace",
        "size": 12,
        "color": "#a6e3a1"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "~/.config/hyprbar/widgets/volume.sh",
        "interval": 5000,
        "font": "monospace",
        "size": 12,
        "color": "#b4befe"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "~/.config/hyprbar/widgets/network.sh",
        "interval": 10000,
        "font": "monospace",
        "size": 12,
        "color": "#74c7ec"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "~/.config/hyprbar/widgets/battery.sh",
        "interval": 30000,
        "font": "monospace",
        "size": 12,
        "color": "#cba6f7"
      }
    }
  ]
}
