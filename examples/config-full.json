{
  "bar": {
    "position": "top",
    "height": 32,
    "background": "#1e1e2ecc",
    "color": "#cdd6f4",
    "font": "Noto Sans, Noto Color Emoji",
    "size": 10,
    "margin": 10,
    "spacing": 10
  },
  "widgets": [
    {
      "type": "script",
      "position": "left",
      "config": {
        "command": "../widgets/date.sh",
        "interval": 1000,
        "color": "#89b4fa"
      }
    },
    {
      "type": "script",
      "position": "left",
      "config": {
        "command": "../widgets/uptime.sh",
        "interval": 60000,
        "color": "#94e2d5"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "../widgets/cpu.sh",
        "interval": 2000,
        "color": "#f38ba8"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "../widgets/memory.sh",
        "interval": 5000,
        "color": "#fab387"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "../widgets/disk.sh",
        "interval": 60000,
        "color": "#a6e3a1"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "../widgets/volume.sh",
        "interval": 5000,
        "color": "#b4befe"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "../widgets/network.sh",
        "interval": 10000,
        "color": "#74c7ec"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "../widgets/battery.sh",
        "interval": 30000,
        "color": "#cba6f7"
      }
    },
    {
      "type": "tray",
      "position": "right",
      "config": {
        "icon_size": 20,
        "spacing": 8
      }
    }
  ]
}
