{
  "bar": {
    "position": "top",
    "height": 30,
    "background": "#1e1e2ecc",
    "foreground": "#cdd6f4",
    "font": "Noto Sans, Noto Color Emoji 14"
  },
  "widgets": [
    {
      "type": "script",
      "position": "left",
      "config": {
        "command": "../widgets/date.sh",
        "interval": 1000,
        "color": "#89b4fa"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "../widgets/cpu.sh",
        "interval": 2000,
        "size": 12,
        "color": "#f38ba8"
      }
    },
    {
      "type": "script",
      "position": "right",
      "config": {
        "command": "../widgets/memory.sh",
        "interval": 5000,
        "size": 12,
        "color": "#fab387"
      }
    }
  ]
}
